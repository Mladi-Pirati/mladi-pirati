---
import { Icon } from "astro-icon/components";
import { footerLinks, siteMetadata, socialLinks } from "../config/site";
---

<footer class="bg-white/3">
  <div class="mx-auto w-full max-w-(--container-width) px-(--page-gutter) py-10">
    <div class="mb-6">
      <div class="flex flex-wrap items-baseline justify-between gap-6">
        <span class="text-[0.8125rem] text-white/50">{siteMetadata.footerText}</span>

        {
          footerLinks.length > 0 && (
            <ul class="m-0 flex list-none flex-wrap gap-4.5 p-0">
              {footerLinks.map((link) => (
                <li>
                  <a
                    class="text-[0.8125rem] text-white/[0.55] transition-colors hover:text-accent"
                    href={link.href}
                    {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noreferrer' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    <hr class="mb-5 border-0 border-t border-border" />

    <div class="flex items-center justify-between gap-3 max-[900px]:flex-col max-[900px]:items-start max-[640px]:items-stretch">
      <p class="m-0 text-[0.8125rem] text-white/34">
        &copy; 2018-{new Date().getFullYear()} {siteMetadata.shortName}. Vse pravice pridrzane.
      </p>

      {
        socialLinks.length > 0 && (
          <ul aria-label="Družbena omrežja" class="m-0 flex list-none gap-3 p-0">
            {socialLinks.map((link) => (
              <li>
                <a
                  aria-label={link.label}
                  class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/[0.14] bg-white/3 text-white/72 transition-[background,border-color,color,transform] duration-150 ease-in hover:-translate-y-px hover:border-white/32 hover:bg-white/8 hover:text-white focus-visible:border-white/32 focus-visible:bg-white/8 focus-visible:text-white"
                  href={link.href}
                  rel="noreferrer"
                  target="_blank"
                  title={link.label}
                >
                  <Icon aria-hidden="true" class="h-4.5 w-4.5" name={link.icon} />
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</footer>
