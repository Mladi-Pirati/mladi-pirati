---
import AboutSection from "../components/AboutSection.astro";
import HeroSection from "../components/HeroSection.astro";
import ProgramSection from "../components/ProgramSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteMetadata } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={siteMetadata.title} description={siteMetadata.description} canonicalPath="/">
  <HeroSection />

  <main id="main-content">
    <hr class="m-0 border-0 border-t border-border" role="presentation" />
    <AboutSection />
    <hr class="m-0 border-0 border-t border-border" role="presentation" />
    <ProgramSection />
  </main>

  <SiteFooter />

  <script>
    import { initHomePage } from "../scripts/home/init-home-page";

    initHomePage();
  </script>
</BaseLayout>
