---
import { DISCORD_URL } from "../config/site";
import { JOIN_FORM_SUCCESS_COPY } from "../internal/join-form";

interface Props {
  hidden?: boolean;
  id?: string;
}

const { hidden = false, id } = Astro.props;
const panelClass =
  "grid w-full max-w-4xl gap-4 border border-border bg-[rgba(8,8,8,0.3)] p-7 shadow-elevated max-[960px]:p-6 max-[640px]:p-[22px]";
const bodyCopyClass = "m-0 text-text-soft";
const primaryActionClass =
  "inline-flex min-h-[50px] items-center justify-center border border-accent bg-accent px-4.5 py-3 font-mono text-[13px] uppercase tracking-[1.2px] text-black transition-colors hover:border-accent-strong hover:bg-accent-strong hover:text-black max-[720px]:w-full";
const secondaryActionClass =
  "inline-flex min-h-[50px] items-center justify-center border border-border-strong bg-transparent px-4.5 py-3 font-mono text-[13px] uppercase tracking-[1.2px] text-text transition-colors hover:border-accent hover:text-text max-[720px]:w-full";
---

<section
  class={panelClass}
  id={id}
  hidden={hidden ? true : undefined}
  tabindex="-1"
  aria-live="polite"
>
  <p class="m-0 font-mono text-xs tracking-[2px] text-accent uppercase">Prijava oddana</p>
  <h2 class="m-0 font-mono text-[clamp(1.9rem,3vw,2.8rem)] leading-[1.15] text-balance">
    Hvala za prijavo!
  </h2>

  {
    JOIN_FORM_SUCCESS_COPY.map((paragraph) => (
      <p class={bodyCopyClass}>{paragraph}</p>
    ))
  }

  <div class="mt-2 flex flex-wrap gap-3">
    <a class={primaryActionClass} href={DISCORD_URL} rel="noreferrer" target="_blank">
      Discord skupina
    </a>
    <a class={secondaryActionClass} href="/">
      Nazaj na prvo stran
    </a>
  </div>
</section>
