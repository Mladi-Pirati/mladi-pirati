---
import { heroContent } from "../config/site";
import HeroJoinCard from "./HeroJoinCard.astro";
import SiteNav from "./SiteNav.astro";
---

<section
  class="relative min-h-screen overflow-hidden bg-canvas max-[900px]:overflow-visible"
  id="hero">
  <canvas
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 z-0 h-full w-full"
    id="hero-ascii"></canvas>
  <div
    class="relative z-2 mx-auto grid max-w-(--wide-width) grid-cols-[minmax(0,1fr)_360px] grid-rows-[auto_auto_1fr_auto] gap-x-20 px-(--page-gutter) pt-[15vh] pb-22.5 max-[900px]:grid-cols-1 max-[900px]:grid-rows-none max-[900px]:gap-y-6 max-[900px]:pt-10 max-[640px]:pt-5">
    <h1
      class="col-start-1 row-start-1 mb-6 font-mono text-[60px] leading-[1.2] font-normal tracking-[-0.5px] text-balance text-text max-[900px]:mb-0 max-[900px]:text-[48px] max-[640px]:text-[36px]">
      {heroContent.headline}
    </h1>
    <p
      class="col-start-1 row-start-2 m-0 font-mono text-[30px] leading-[1.2] font-normal tracking-[-0.5px] text-text max-[640px]:text-[24px]">
      {heroContent.summary}<span id="hero-quote-loop"></span>
    </p>
    <div
      aria-hidden="true"
      class="pointer-events-none col-start-1 row-start-3 mt-6 w-full max-w-115 select-none max-[900px]:mt-0 max-[900px]:max-w-95 max-[640px]:max-w-[320px]">
      <img
        class="block h-auto w-full drop-shadow-[0_26px_54px_rgba(0,0,0,0.34)]"
        src="/piratosan.png"
        alt=""
        width="1200"
        height="1410"
        decoding="async"
      />
    </div>
    <div
      class="col-start-2 row-span-full row-start-1 self-start max-[900px]:col-auto max-[900px]:row-auto">
      <HeroJoinCard />
    </div>
    <p
      class="col-start-1 row-end-4 m-0 self-end font-mono text-base leading-[1.3] tracking-[-0.5px] text-text max-[900px]:self-auto max-[900px]:text-[18px] max-[640px]:text-base">
      {heroContent.cta[0]}
      <a href="https://prt.si" target="_blank" class="underline"
        >{heroContent.cta[1]}</a
      >
    </p>
  </div>
  <SiteNav />
</section>
