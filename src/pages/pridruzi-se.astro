---
import JoinSuccessPanel from "../components/JoinSuccessPanel.astro";
import { DISCORD_URL, siteMetadata } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  JOIN_FORM_INTRO,
  JOIN_FORM_PATH,
  JOIN_REQUEST_API_PATH,
  PARTICIPATION_MODES,
  PROGRAM_URL,
  REGIONS,
  STATUTE_URL,
  getJoinDateBounds,
} from "../internal/join-form";

const submitted = Astro.url.searchParams.get("submitted") === "1";
const submissionError = Astro.url.searchParams.get("error") === "1";
const { min, max } = getJoinDateBounds(new Date());
const bodyCopyClass = "m-0 text-text-soft";
const surfaceClass = "border border-border bg-[rgba(8,8,8,0.3)]";
const introClass = `${surfaceClass} p-8 max-[960px]:p-6`;
const panelClass = `${surfaceClass} p-7 shadow-elevated max-[960px]:p-6 max-[640px]:p-[22px]`;
const fieldClass = "group flex flex-col gap-2";
const fieldWideClass = `${fieldClass} col-span-full`;
const labelClass =
  "font-mono text-xs uppercase tracking-[1.2px] text-accent group-data-[invalid=true]:text-danger";
const controlClass =
  "w-full min-h-[52px] rounded-none border border-border bg-white/[0.02] px-3.5 py-[13px] text-text outline-none transition-colors placeholder:text-white/[0.32] focus-visible:border-accent disabled:cursor-not-allowed disabled:opacity-70 group-data-[invalid=true]:border-danger";
const choiceClass =
  "grid cursor-pointer grid-cols-[auto_1fr] items-start gap-3 border border-border bg-white/[0.02] p-3.5 transition-colors group-data-[invalid=true]:border-danger";
const primaryActionClass =
  "inline-flex min-h-[50px] items-center justify-center border border-accent bg-accent px-4.5 py-3 font-mono text-[13px] uppercase tracking-[1.2px] text-black transition-colors hover:border-accent-strong hover:bg-accent-strong hover:text-black max-[720px]:w-full";
const secondaryActionClass =
  "inline-flex min-h-[50px] items-center justify-center border border-border-strong bg-transparent px-4.5 py-3 font-mono text-[13px] uppercase tracking-[1.2px] text-text transition-colors hover:border-accent hover:text-text max-[720px]:w-full";
const helperLinkClass = "text-accent transition-colors hover:text-accent-strong";
---

<BaseLayout
  title="Pridruži se"
  description="Uradna pristopnica za članstvo v Mladih Piratih."
  canonicalPath={JOIN_FORM_PATH}
>
  <main
    class="min-h-screen px-(--page-gutter) pt-8 pb-18 max-[720px]:pt-5 max-[720px]:pb-14"
    id="main-content"
  >
    <header class="mx-auto mb-12 flex w-full max-w-(--wide-width) flex-wrap items-center justify-between gap-4.5 max-[720px]:mb-7">
      <a class="inline-flex items-center gap-3.5 text-text hover:text-text max-[720px]:w-full" href="/">
        <img
          class="h-11 w-11 object-contain"
          src="/logos/Pirati_MladiPirati_Logo_3.png"
          alt={siteMetadata.shortName}
          width="44"
          height="44"
        />
        <span class="grid gap-0.5">
          <span class="font-mono text-xs uppercase tracking-[2px] text-accent">
            {siteMetadata.shortName}
          </span>
          <span class="text-sm text-text-soft">Podmladek Piratske stranke Slovenije</span>
        </span>
      </a>

      <a class={secondaryActionClass} href="/#hero">
        ← Nazaj na prvo stran
      </a>
    </header>

    <section class="mx-auto flex w-full max-w-(--wide-width) flex-col items-center gap-8">
      {
        submitted ? (
          <JoinSuccessPanel />
        ) : (
          <div class="grid w-full max-w-4xl gap-8">
            <div class={introClass}>
              <p class="mb-3.5 font-mono text-xs uppercase tracking-[2px] text-accent">
                Pristopnica
              </p>
              <h1 class="m-0 text-balance font-mono text-[clamp(2rem,4vw,3.4rem)] leading-[1.15]">
                Prijava za članstvo v Mladih Piratih
              </h1>

              {
                JOIN_FORM_INTRO.map((paragraph) => (
                  <p class:list={[bodyCopyClass, "mt-3.5" ]}>
                    {paragraph}
                  </p>
                ))
              }
            </div>
            <section class:list={[panelClass, "grid gap-7"]} id="join-form-shell">
              <div class="grid gap-2.5">
                <h2 class="m-0 text-balance font-mono text-[1.75rem] leading-[1.15]">
                  Izpolni pristopnico
                </h2>
                <p class={bodyCopyClass}>
                  Polja označena z zvezdico so obvezna. Po oddaji prijavo pregleda
                  upravni odbor.
                </p>
              </div>

              {submissionError && (
                <p
                  class="m-0 text-[0.85rem] leading-[1.5] text-text-muted empty:hidden data-[tone=error]:text-danger data-[tone=muted]:text-text-muted"
                  data-tone="error"
                >
                  Oddaja trenutno ni uspela. Preveri podatke in poskusi znova.
                </p>
              )}

              <form
                action={JOIN_REQUEST_API_PATH}
                class="grid gap-7 data-[submitting=true]:opacity-[0.88]"
                id="join-request-form"
                method="post"
              >
                <section class="grid gap-5 border-t border-border pt-6 first:border-t-0 first:pt-0" aria-labelledby="join-personal-title">
                  <div class="grid grid-cols-[auto_1fr] items-start gap-4">
                    <p class="m-0 text-lg text-white/[0.24]">1</p>
                    <div>
                      <h3 class="mb-1.5 text-[1.2rem]" id="join-personal-title">
                        Osebni podatki
                      </h3>
                      <p class={bodyCopyClass}>
                        Osnovne informacije, ki jih potrebujemo za obravnavo
                        pristopnice.
                      </p>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-4 max-[720px]:grid-cols-1">
                    <div class={fieldWideClass} data-field-wrapper="fullName">
                      <label class={labelClass} for="fullName">
                        Ime in priimek *
                      </label>
                      <input
                        autocomplete="name"
                        class={controlClass}
                        id="fullName"
                        maxlength="160"
                        minlength="2"
                        name="fullName"
                        placeholder="npr. Ana Novak"
                        required
                        type="text"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="fullName"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="dateOfBirth">
                      <label class={labelClass} for="dateOfBirth">
                        Datum rojstva *
                      </label>
                      <input
                        autocomplete="bday"
                        class={controlClass}
                        id="dateOfBirth"
                        max={max}
                        min={min}
                        name="dateOfBirth"
                        required
                        type="date"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="dateOfBirth"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="placeOfBirth">
                      <label class={labelClass} for="placeOfBirth">
                        Kraj rojstva *
                      </label>
                      <input
                        class={controlClass}
                        id="placeOfBirth"
                        maxlength="160"
                        minlength="2"
                        name="placeOfBirth"
                        placeholder="npr. Celje"
                        required
                        type="text"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="placeOfBirth"></p>
                    </div>
                  </div>
                </section>

                <section class="grid gap-5 border-t border-border pt-6 first:border-t-0 first:pt-0" aria-labelledby="join-contact-title">
                  <div class="grid grid-cols-[auto_1fr] items-start gap-4">
                    <p class="m-0 text-lg text-white/[0.24]">2</p>
                    <div>
                      <h3 class="mb-1.5 text-[1.2rem]" id="join-contact-title">
                        Kontakt in prebivališče
                      </h3>
                      <p class={bodyCopyClass}>
                        Podatki za članstvo, obveščanje in povezovanje z lokalnim
                        okoljem.
                      </p>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-4 max-[720px]:grid-cols-1">
                    <div class={fieldWideClass} data-field-wrapper="streetAddress">
                      <label class={labelClass} for="streetAddress">
                        Stalno prebivališče (ulica, hišna številka) *
                      </label>
                      <input
                        autocomplete="street-address"
                        class={controlClass}
                        id="streetAddress"
                        maxlength="160"
                        minlength="5"
                        name="streetAddress"
                        placeholder="npr. Trubarjeva cesta 24"
                        required
                        type="text"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="streetAddress"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="cityAndPostalCode">
                      <label class={labelClass} for="cityAndPostalCode">
                        Kraj in poštna številka *
                      </label>
                      <input
                        autocomplete="postal-code"
                        class={controlClass}
                        id="cityAndPostalCode"
                        maxlength="160"
                        minlength="3"
                        name="cityAndPostalCode"
                        placeholder="npr. 1000 Ljubljana"
                        required
                        type="text"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="cityAndPostalCode"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="residenceRegion">
                      <label class={labelClass} for="residenceRegion">
                        Regija prebivališča *
                        <span class="ml-2 text-[0.5rem] text-text-soft">
                          Za potrebe lokalnih volitev in lokalnih odborov.
                        </span>
                      </label>
                      <div class="relative">
                        <select
                          class={`${controlClass} appearance-none pr-12`}
                          id="residenceRegion"
                          name="residenceRegion"
                          required
                        >
                          <option value="">Izberi regijo.</option>
                        {
                          REGIONS.map((region) => (
                            <option value={region}>{region}</option>
                          ))
                        }
                        </select>
                        <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-accent">
                          <span class="h-2 w-2 rotate-45 border-r-2 border-b-2 border-current"></span>
                        </span>
                      </div>
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="residenceRegion"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="email">
                      <label class={labelClass} for="email">
                        E-pošta *
                      </label>
                      <input
                        autocomplete="email"
                        class={controlClass}
                        id="email"
                        maxlength="160"
                        name="email"
                        placeholder="ime@primer.si"
                        required
                        type="email"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="email"></p>
                    </div>

                    <div class={fieldClass} data-field-wrapper="phone">
                      <label class={labelClass} for="phone">
                        Telefonska številka
                      </label>
                      <input
                        autocomplete="tel"
                        class={controlClass}
                        id="phone"
                        maxlength="40"
                        name="phone"
                        placeholder="npr. 031 123 456"
                        type="tel"
                      />
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="phone"></p>
                    </div>
                  </div>
                </section>

                <section class="grid gap-5 border-t border-border pt-6 first:border-t-0 first:pt-0" aria-labelledby="join-participation-title">
                  <div class="grid grid-cols-[auto_1fr] items-start gap-4">
                    <p class="m-0 text-lg text-white/[0.24]">3</p>
                    <div>
                      <h3 class="mb-1.5 text-[1.2rem]" id="join-participation-title">
                        Sodelovanje
                      </h3>
                      <p class={bodyCopyClass}>
                        Povej nam, kako želiš sodelovati in kako te najlažje
                        vključimo naprej.
                      </p>
                    </div>
                  </div>

                  <fieldset class="group flex flex-col gap-2" data-field-wrapper="participationMode">
                    <legend class={`${labelClass} pb-2`}>Oblika sodelovanja *</legend>
                    <div class="grid gap-3">
                      {
                        PARTICIPATION_MODES.map((mode) => (
                          <label class={choiceClass}>
                            <input
                              class="mt-0.75 accent-accent"
                              name="participationMode"
                              required
                              type="radio"
                              value={mode}
                            />
                            <span class="text-[0.95rem] leading-[1.6] text-text-soft">{mode}</span>
                          </label>
                        ))
                      }
                    </div>
                    <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="participationMode"></p>
                  </fieldset>

                  <div class="grid grid-cols-2 gap-4 max-[720px]:grid-cols-1">
                    <div class={fieldWideClass} data-field-wrapper="discordUsername">
                      <label class={labelClass} for="discordUsername">
                        Uporabniško ime na Discordu
                      </label>
                      <input
                        autocapitalize="none"
                        autocomplete="off"
                        class={controlClass}
                        id="discordUsername"
                        maxlength="120"
                        name="discordUsername"
                        placeholder="npr. piratec ali @piratec"
                        spellcheck="false"
                        type="text"
                      />
                      <p class="m-0 text-[0.92rem] text-text-soft">
                        Če želiš aktivno sodelovati, vpis ni obvezen; aktivni člani
                        v Discord skupini pridobijo dostop do več kanalov.
                      </p>
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="discordUsername"></p>
                    </div>

                    <div class={fieldWideClass} data-field-wrapper="motivation">
                      <label class={labelClass} for="motivation">
                        Zakaj želiš postati član Mladih Piratov?
                      </label>
                      <textarea
                        class={controlClass}
                        id="motivation"
                        maxlength="4000"
                        name="motivation"
                        placeholder="Napiši nam nekaj besed o sebi in zakaj te zanima članstvo..."
                        rows="4"
                      ></textarea>
                      <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="motivation"></p>
                    </div>
                  </div>
                </section>

                <section class="grid gap-5 border-t border-border pt-6 first:border-t-0 first:pt-0" aria-labelledby="join-consent-title">
                  <div class="grid grid-cols-[auto_1fr] items-start gap-4">
                    <p class="m-0 text-lg text-white/[0.24]">4</p>
                    <div>
                      <h3 class="mb-1.5 text-[1.2rem]" id="join-consent-title">
                        Izjave
                      </h3>
                      <p class={bodyCopyClass}>
                        Pred oddajo moramo potrditi še zakonske in statutarne izjave.
                      </p>
                    </div>
                  </div>

                  <fieldset class="group flex flex-col gap-2" data-field-wrapper="consentsToDataProcessing">
                    <legend class={`${labelClass} pb-2`}>
                      Soglasje za obdelavo osebnih podatkov *
                    </legend>
                    <label class={choiceClass}>
                      <input
                        class="mt-0.75 accent-accent"
                        name="consentsToDataProcessing"
                        required
                        type="checkbox"
                        value="true"
                      />
                      <span class="grid gap-1.5">
                        <span class="text-text">
                          Soglašam z obdelavo osebnih podatkov za namene vodenja
                          registra članstva v skladu z GDPR / ZVOP-2.
                        </span>
                        <span class="text-[0.95rem] leading-[1.6] text-text-soft">
                          Mladi Pirati bodo moje osebne podatke zbirali, obdelovali
                          in hranili izključno za namene vodenja registra članstva
                          ter pošiljanja obvestil o aktivnostih organizacije, v
                          skladu z GDPR in ZVOP-2.
                        </span>
                      </span>
                    </label>
                    <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="consentsToDataProcessing"></p>
                  </fieldset>

                  <fieldset class="group flex flex-col gap-2" data-field-wrapper="acceptsStatuteAndProgram">
                    <legend class={`${labelClass} pb-2`}>
                      Potrditev statuta in programa *
                    </legend>
                    <label class={choiceClass}>
                      <input
                        class="mt-0.75 accent-accent"
                        name="acceptsStatuteAndProgram"
                        required
                        type="checkbox"
                        value="true"
                      />
                      <span class="grid gap-1.5">
                        <span class="text-text">
                          Potrjujem, da sprejemam statut in program Mladih Piratov
                          ter Piratske stranke.
                        </span>
                        <span class="text-[0.95rem] leading-[1.6] text-text-soft">
                          Sem državljan/-ka Republike Slovenije, vstopam v Mlade
                          Pirate in sprejemam njihov{" "}
                          <a
                            class={helperLinkClass}
                            href={STATUTE_URL}
                            target="_blank"
                            rel="noreferrer"
                          >
                            statut
                          </a>{" "}
                          ter{" "}
                          <a
                            class={helperLinkClass}
                            href={PROGRAM_URL}
                            target="_blank"
                            rel="noreferrer"
                          >
                            program
                          </a>
                          . S soglasjem izjavljam, da so vsi posredovani podatki resnični.
                        </span>
                      </span>
                    </label>
                    <p class="m-0 text-[0.85rem] leading-[1.5] text-danger empty:hidden" data-error-for="acceptsStatuteAndProgram"></p>
                  </fieldset>
                </section>

                <div class="flex flex-wrap items-center gap-4 max-[720px]:items-stretch">
                  <button class={primaryActionClass} type="submit">
                    Oddaj prijavnico
                  </button>
                  <p class="m-0 text-[0.92rem] leading-[1.6] text-text-soft">
                    Po oddaji te vabimo tudi v našo{" "}
                    <a class={helperLinkClass} href={DISCORD_URL} rel="noreferrer" target="_blank">
                      Discord skupino
                    </a>.
                  </p>
                </div>

                <p
                  class="m-0 text-[0.85rem] leading-[1.5] text-text-muted empty:hidden data-[tone=error]:text-danger data-[tone=muted]:text-text-muted"
                  id="join-form-status"
                ></p>
              </form>
            </section>

            <JoinSuccessPanel hidden id="join-success-panel" />
          </div>
        )
      }
    </section>
  </main>

  <script>
    import { initJoinForm } from "../scripts/join/join-form";

    initJoinForm();
  </script>
</BaseLayout>
