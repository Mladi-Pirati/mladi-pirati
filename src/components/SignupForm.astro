---
const signupEndpoint = import.meta.env.PUBLIC_SIGNUP_ENDPOINT?.trim() ?? "";

interface FormField {
  autocomplete?: string;
  hint?: string;
  id: string;
  inputMode?:
    | "decimal"
    | "email"
    | "none"
    | "numeric"
    | "search"
    | "tel"
    | "text"
    | "url";
  label: string;
  maxLength?: number;
  minLength?: number;
  name: string;
  placeholder: string;
  required?: boolean;
  rows?: number;
  spellcheck?: boolean;
  type: "email" | "number" | "text" | "textarea";
  wide?: boolean;
}

const fields: FormField[] = [
  {
    autocomplete: "off",
    id: "ime",
    label: "ime",
    minLength: 2,
    name: "first_name",
    placeholder: "kako ti je ime?",
    required: true,
    type: "text",
  },
  {
    autocomplete: "off",
    id: "priimek",
    label: "priimek",
    minLength: 2,
    name: "last_name",
    placeholder: "in priimek?",
    required: true,
    type: "text",
  },
  {
    autocomplete: "off",
    id: "email",
    label: "email",
    name: "email",
    placeholder: "obljubimo, brez spama",
    required: true,
    spellcheck: false,
    type: "email",
  },
  {
    autocomplete: "off",
    id: "starost",
    inputMode: "numeric",
    label: "letnik rojstva",
    name: "birth_year",
    placeholder: "npr. 2002",
    required: true,
    type: "text",
  },
  {
    autocomplete: "off",
    id: "mesto",
    label: "mesto",
    name: "city",
    placeholder: "npr. Ljubljana",
    required: true,
    type: "text",
  },
  {
    id: "motivacija",
    hint: "(maks. 100 besed)",
    label: "motivacija",
    maxLength: 600,
    name: "motivation",
    placeholder: "kaj bi spremenil/a?",
    rows: 2,
    type: "textarea",
    wide: true,
  },
];
---

<form
  class="hero-form"
  id="signup-form"
  action={signupEndpoint}
  method="post"
  autocomplete="off"
  aria-label="Pristopnica za Mlade Pirate"
  data-signup-configured={signupEndpoint ? "true" : "false"}
>
  <div class="form-honeypot" aria-hidden="true">
    <label for="company">website</label>
    <input
      id="company"
      name="company"
      type="text"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <div class="form-fields">
    {
      fields.map((field) => {
        const errorId = `${field.id}-error`;
        const inputClassName = field.wide
          ? "prompt-line prompt-line-wide"
          : "prompt-line";

        return (
          <>
            <div class={inputClassName} data-field-wrapper={field.name}>
              <label for={field.id} class="prompt-label">
                {field.label}
                {field.hint && <span class="prompt-hint">{field.hint}</span>}
              </label>

              {field.type === "textarea" ? (
                <textarea
                  id={field.id}
                  name={field.name}
                  rows={field.rows}
                  maxlength={field.maxLength}
                  placeholder={field.placeholder}
                  autocomplete={field.autocomplete}
                  data-signup-field
                  aria-describedby={errorId}
                ></textarea>
              ) : (
                <input
                  id={field.id}
                  type={field.type}
                  name={field.name}
                  placeholder={field.placeholder}
                  autocomplete={field.autocomplete}
                  minlength={field.minLength}
                  maxlength={field.maxLength}
                  inputmode={field.inputMode}
                  required={field.required}
                  spellcheck={field.spellcheck === false ? "false" : undefined}
                  data-signup-field
                  aria-describedby={errorId}
                />
              )}
            </div>

            <p class="field-error" id={errorId} data-error-for={field.name}></p>
          </>
        );
      })
    }

    <div class="form-primary-actions">
      <button type="submit" class="form-submit" id="primary-submit">
        pridruži se nam
      </button>
    </div>
  </div>

  <div class="form-consent" id="form-consent">
    <p class="consent-title">S to izjavo dajem soglasje do preklica:</p>

    <label class="consent-check" for="consent-data">
      <input
        type="checkbox"
        id="consent-data"
        name="consent_data"
        value="yes"
        required
        aria-describedby="consent-data-error"
      />
      <span>
        da Mladi Pirati skladno z veljavno zakonodajo s področja varstva osebnih
        podatkov in Splošno uredbo EU o varstvu podatkov zbirajo, obdelujejo,
        uporabljajo, shranjujejo in ažurirajo moje osebne podatke ter mi po
        elektronski pošti pošiljajo obvestila v zvezi s članstvom in aktivnostmi
        organizacije.
      </span>
    </label>

    <p class="field-error consent-error" id="consent-data-error"></p>

    <div class="form-consent-actions">
      <button type="button" class="form-submit" id="consent-submit">
        potrdi in pošlji
      </button>
      <button type="button" class="form-back" id="consent-back">
        ← nazaj
      </button>
    </div>
  </div>
</form>
