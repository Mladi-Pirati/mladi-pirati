---
import { heroContent } from "../config/site";
import HeroJoinCard from "./HeroJoinCard.astro";
import SiteNav from "./SiteNav.astro";
---

<section class="hero" id="hero">
  <canvas class="hero-ascii" id="hero-ascii" aria-hidden="true"></canvas>
  <div class="hero-inner">
    <h1 class="form-preamble">{heroContent.headline}</h1>
    <p class="hero-quote-text">
      {heroContent.summary}<span id="hero-quote-loop"></span>
    </p>
    <div class="hero-art" aria-hidden="true">
      <picture>
        <img
          class="hero-art-image"
          src="/pirato-san.png"
          alt=""
          width="1200"
          height="1410"
          decoding="async"
        />
      </picture>
    </div>
    <HeroJoinCard />
    <p class="hero-quote-cta">{heroContent.cta}</p>
  </div>
  <SiteNav />
</section>
