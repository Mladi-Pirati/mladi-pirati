---
import { programContent } from "../config/site";
---

<section
  class="scroll-mt-[calc(var(--nav-height)+20px)] bg-white/[0.03] py-20"
  id="program"
  aria-labelledby="program-title"
>
  <div class="mx-auto w-full max-w-(--container-width) px-(--page-gutter)">
    <div class="max-w-[820px]">
      <h2
        class="mb-3 text-[28px] font-bold uppercase tracking-[2px] text-balance"
        id="program-title"
      >
        Naš <span class="text-accent">program</span>
      </h2>
      <p class="mb-12 max-w-[640px] text-text-muted">{programContent.subtitle}</p>

      <div class="grid">
        {
          programContent.items.map((item) => (
            <article class="border-b border-border py-6 last:border-b-0">
              <div>
                <h3 class="mb-1.5 text-base">{item.title}</h3>
                <p class="m-0 text-[0.95rem] text-text-muted">{item.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
