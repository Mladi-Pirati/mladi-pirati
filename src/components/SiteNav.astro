---
import { navigationItems, siteMetadata } from "../config/site";
---

<nav class="site-nav" id="site-nav" aria-label="Glavna navigacija">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <img
        src="/logos/Pirati_MladiPirati_Logo_3.png"
        alt={siteMetadata.shortName}
        width="36"
        height="36"
      />
    </a>

    <ul class="nav-menu" id="nav-menu">
      {
        navigationItems.map((item) => (
          <li>
            <a href={item.href} class:list={{ "nav-highlight": item.highlighted }}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      class="scroll-down-arrow"
      id="scroll-arrow"
      type="button"
      aria-label="Pomakni se navzdol"
    >
      <span class="arrow-pair" aria-hidden="true">
        <svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor">
          <rect x="0" y="0" width="2" height="2"></rect>
          <rect x="12" y="0" width="2" height="2"></rect>
          <rect x="2" y="2" width="2" height="2"></rect>
          <rect x="10" y="2" width="2" height="2"></rect>
          <rect x="4" y="4" width="2" height="2"></rect>
          <rect x="8" y="4" width="2" height="2"></rect>
          <rect x="6" y="6" width="2" height="2"></rect>
        </svg>
        <svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor">
          <rect x="0" y="0" width="2" height="2"></rect>
          <rect x="12" y="0" width="2" height="2"></rect>
          <rect x="2" y="2" width="2" height="2"></rect>
          <rect x="10" y="2" width="2" height="2"></rect>
          <rect x="4" y="4" width="2" height="2"></rect>
          <rect x="8" y="4" width="2" height="2"></rect>
          <rect x="6" y="6" width="2" height="2"></rect>
        </svg>
      </span>
    </button>

    <button
      class="nav-toggle"
      id="nav-toggle"
      type="button"
      aria-label="Odpri meni"
      aria-controls="nav-menu"
      aria-expanded="false"
    >
      &#9776;
    </button>
  </div>
</nav>
